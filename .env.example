# OpenAI-compatible API base URL
API_URL=http://127.0.0.1:1234

# Model name exposed by your OpenAI-compatible server
LLM_MODEL=google/gemma-3-4b

# Required by OpenAI-compatible clients. Use any placeholder if your local server ignores it.
OPENAI_API_KEY=sk-local-dev

# External system prompt URL (raw text/markdown)
SYSTEM_PROMPT_URL=https://raw.githubusercontent.com/microsoft/agent-framework/main/README.md

